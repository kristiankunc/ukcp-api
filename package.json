{
    "name": "ukcp-api",
    "version": "0.0.2",
    "type": "module",
    "description": "TypeScript API wrapper for the VATSIM UK Controller Plugin public API",
    "repository": {
        "type": "git",
        "url": "https://github.com/kristiankunc/ukcp-api"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "npm run build",
        "format": "prettier --write ."
    },
    "keywords": [
        "vatsim",
        "ukcp",
        "api",
        "controller-plugin"
    ],
    "license": "MIT",
    "devDependencies": {
        "prettier": "^3.9.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
